{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["${mod_author}"],
  "contact": {
    "homepage": "${mod_website}",
    "sources": "${mod_website}",
    "issues": "${mod_website}/issues"
  },
  "license": "${mod_license}",
  "icon": "assets/lt-x-ec/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": ["com.alfakynz.ltxec.Ltxec"]
  },
  "mixins": ["lt-x-ec.mixins.json"],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  }
}
